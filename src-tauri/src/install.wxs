<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Fragment>
        <!-- 引用 Tauri 主安装程序生成的 ComponentGroup，确保我们的 Registry 组件被包含 -->
        <ComponentGroup Id="CustomFileIcons">
            <Component Id="FileTypeIcon" Directory="INSTALLFOLDER" Guid="PUT-A-NEW-GUID-HERE">
                <!-- 为 .fcplug 设置默认图标为应用主可执行文件（图标自动取自 .exe 内嵌资源） -->
                <RegistryKey Root="HKCR" Key=".fcplug\DefaultIcon">
                    <RegistryValue Type="string" Value="[#cm_FlowCloudAI.exe]"/>
                </RegistryKey>
                <!-- 可选：同时指定文件类型的友好名称（已有 fileAssociations 配置，可不重复） -->
                <RegistryKey Root="HKCR" Key=".fcplug">
                    <RegistryValue Type="string" Value="FlowCloudAI.plugin"/>
                </RegistryKey>
                <RegistryKey Root="HKCR" Key="FlowCloudAI.plugin\DefaultIcon">
                    <RegistryValue Type="string" Value="[#cm_FlowCloudAI.exe]"/>
                </RegistryKey>
            </Component>
        </ComponentGroup>
    </Fragment>
</Wix>