{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "流云AI",
  "version": "0.1.0",
  "identifier": "com.tauri.flowcloudai",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "流云AI",
        "label": "main",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "zoomHotkeysEnabled": true,
        "fullscreen": false,
        "visible": false,
        "backgroundColor": [0,0,0],
        "transparent": true,
        "decorations": false,
        "center": true,
        "incognito": true,
        "additionalBrowserArgs": "--disable-extensions --disable-background-networking --disable-sync --metrics-recording-only --disable-features=Spellcheck,AutofillServerCommunication,Translate --disable-component-update --disable-default-apps --disable-domain-reliability --no-first-run --disable-gpu --disable-features=AudioServiceOutOfProcess --js-flags=\"--max-old-space-size=128\" --renderer-process-limit=1 --disable-renderer-backgrounding --disable-backgrounding-occluded-windows"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://asset.localhost",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
